% textanalysis.sty
% Hugging Face 텍스트 분석 입문 — 디자인 시스템 패키지
% v0.1 (2026-05-02)
%
% Cool slate palette · 명조체 타이포그래피 · 통일된 박스/속지/표지
%
% 사용 엔진: XeLaTeX (또는 LuaLaTeX)
% 필요 패키지: xcolor, tikz, tcolorbox, fontspec(또는 xeCJK)

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{textanalysis}[2026/05/02 v0.1 Hugging Face Text Analysis Design System]

\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{listings, skins}
\usetikzlibrary{calc, positioning}

% =========================================================
% 색상 팔레트 — Cool Slate
% =========================================================

% 베이스
\definecolor{taPaper}{HTML}{ECEEED}        % 종이 배경 (밝음)
\definecolor{taPaperDeep}{HTML}{D5D9D8}    % 종이 배경 (어두움)
\definecolor{taInk}{HTML}{1B2733}          % 본문 잉크
\definecolor{taSubtext}{HTML}{4F5A6A}      % 보조 텍스트
\definecolor{taSlateMute}{HTML}{6B7986}    % 흐린 슬레이트
\definecolor{taTrack}{HTML}{1B2733}        % 막대 트랙

% 슬레이트 블루 (메인 액센트)
\definecolor{taSlate}{HTML}{4F6D8C}        % 메인 액센트
\definecolor{taSlateLight}{HTML}{6E8AA6}   % 옅은 액센트

% Phase 색상 (옅음 → 깊음 진행)
\definecolor{taPhaseZero}{HTML}{8DA3B8}    % Phase 0 (기초)
\definecolor{taPhaseOne}{HTML}{5E7D9C}     % Phase 1 (BERT 기반 태스크 재정식화)
\definecolor{taPhaseTwo}{HTML}{3F5E80}     % Phase 2 (한국어 BERT)
\definecolor{taPhaseThree}{HTML}{243F62}   % Phase 3 (토크나이저)

% Phase 색상 — 숫자 인덱스 별칭 (TikZ key=value 옵션에서 사용하기 위함)
\colorlet{taPhase0}{taPhaseZero}
\colorlet{taPhase1}{taPhaseOne}
\colorlet{taPhase2}{taPhaseTwo}
\colorlet{taPhase3}{taPhaseThree}

% =========================================================
% Phase 색상 디스패처
% \taphasecolor{N} → "taPhaseN" 색상 이름 (확장 가능)
% =========================================================
\newcommand{\taphasecolor}[1]{taPhase#1}

% =========================================================
% Box 환경 — 모두 슬레이트 팔레트로 통일
% =========================================================

\tcbset{
  taboxbase/.style={
    enhanced, breakable,
    sharp corners,
    boxrule=0pt,
    left=12pt, right=12pt, top=10pt, bottom=10pt,
    fontupper=\color{taInk},
  }
}

% 1. 참고 (note) — 좌측 슬레이트 라인
\newtcolorbox{tanote}[1][참고]{taboxbase,
  colback=taPaper, colframe=taSlate,
  leftrule=2.5pt,
  before upper={\noindent{\sffamily\small\bfseries\color{taSlate}#1}\par\vspace{6pt}},
}

% 2. 정의 (definition) — 슬레이트 프레임
\newtcolorbox{tadefine}[1][정의]{taboxbase,
  colback=white, colframe=taSlate,
  boxrule=0.6pt,
  arc=2pt,
  before upper={%
    \noindent{\sffamily\small\bfseries\color{taSlate}#1}\par
    \vspace{3pt}{\color{taSlateLight}\hrule height 0.4pt}\vspace{6pt}%
  },
}

% 3. 팁 (tip) — 옅은 슬레이트 배경
\newtcolorbox{tatip}[1][팁]{taboxbase,
  colback=taPaper, colframe=taPaper,
  before upper={\noindent{\itshape\small\color{taSlate}\textbullet\ #1}\par\vspace{4pt}},
}

% 4. 중요 (important) — 깊은 슬레이트 좌측 라인
\newtcolorbox{taimportant}[1][중요]{taboxbase,
  colback=taPaper, colframe=taPhaseTwo,
  leftrule=3pt,
  before upper={\noindent{\sffamily\small\bfseries\color{taPhaseTwo}#1}\par\vspace{6pt}},
}

% 5. 인사이트 (insight) — 위아래 룰, 이탤릭
\newtcolorbox{tainsight}{taboxbase,
  colback=white, colframe=white,
  boxrule=0pt, toprule=0.6pt, bottomrule=0.6pt,
  frame style={taSlate},
  fontupper=\itshape\color{taInk},
  left=18pt, right=18pt, top=12pt, bottom=12pt,
}

% 6. 코드 (code listing) — verbatim 지원, 좌측 슬레이트 라인
\newtcblisting{tacode}[1][코드]{%
  enhanced, breakable,
  colback=taPaper, colframe=taPhaseOne,
  sharp corners,
  boxrule=0pt, leftrule=2pt,
  arc=0pt, outer arc=0pt,
  left=12pt, right=12pt, top=22pt, bottom=10pt,
  fonttitle=\sffamily\footnotesize\bfseries,
  coltitle=taPhaseOne,
  colbacktitle=taPaper,
  title={#1},
  attach boxed title to top left={xshift=12pt, yshift=-12pt},
  boxed title style={
    colback=taPaper, colframe=taPaper,
    sharp corners, boxrule=0pt,
  },
  listing only,
  listing options={
    basicstyle=\ttfamily\small\color{taInk},
    breaklines=true,
    keepspaces=true,
    columns=flexible,
    showstringspaces=false,
  },
}

% =========================================================
% Phase 속지 페이지
% \phasedivider{N}{한글제목}{한글부제}{영문부제}{챕터목록}
% 챕터목록 안에서 \chapline{Ch X}{타이틀}{서브타이틀} 사용
% =========================================================

\newcounter{taphasecur}

\newcommand{\chapline}[3]{%
  \noindent
  \makebox[20mm][l]{\itshape\small\color{\taphasecolor{\thetaphasecur}}#1}%
  {\sffamily\bfseries\color{taInk}#2}%
  {\sffamily\color{taSubtext}\ \,\textbf{·}\,\ #3}\par
  \vspace{6pt}%
}

\newcommand{\phasedivider}[5]{%
  \setcounter{taphasecur}{#1}%
  \cleardoublepage
  \thispagestyle{empty}
  \begin{tikzpicture}[remember picture, overlay]
    % 배경
    \fill[taPaper]
      (current page.north west) rectangle (current page.south east);
    % 상단 액센트
    \fill[\taphasecolor{#1}]
      (current page.north west) rectangle ([yshift=-2.5mm]current page.north east);
    % 러닝 헤더
    \node[anchor=north west, text=taSubtext, font=\sffamily\fontsize{7}{9}\selectfont]
      at ([xshift=20mm, yshift=-15mm]current page.north west)
      {HUGGING FACE 텍스트 분석 입문};
    \node[anchor=north east, text=taSubtext, font=\sffamily\fontsize{7}{9}\selectfont]
      at ([xshift=-20mm, yshift=-15mm]current page.north east)
      {0\the\value{taphasecur}\,/\,04};
    \draw[taInk, line width=0.3pt, opacity=0.18]
      ([xshift=20mm, yshift=-19mm]current page.north west) --
      ([xshift=-20mm, yshift=-19mm]current page.north east);
    % PHASE 라벨
    \node[anchor=center, text=taSubtext, font=\sffamily\fontsize{10}{12}\selectfont]
      at ([yshift=-50mm]current page.north)
      {P\,H\,A\,S\,E};
    % 거대한 Phase 번호
    \node[anchor=center, text=\taphasecolor{#1}, font=\bfseries\fontsize{120}{120}\selectfont]
      at ([yshift=-95mm]current page.north)
      {#1};
    % 한글 제목
    \node[anchor=center, text=taInk, font=\bfseries\fontsize{30}{34}\selectfont]
      at ([yshift=-130mm]current page.north) {#2};
    % 한글 부제
    \node[anchor=center, text=taSlate, font=\fontsize{11}{13}\selectfont]
      at ([yshift=-138mm]current page.north) {#3};
    % 영문 부제
    \node[anchor=center, text=taSlateMute, font=\itshape\fontsize{10}{12}\selectfont]
      at ([yshift=-144mm]current page.north) {#4};
    % 디바이더
    \draw[\taphasecolor{#1}, line width=1.2pt]
      ([xshift=-7mm, yshift=-150mm]current page.north) -- ++(14mm, 0);
    % 챕터 목록 (minipage)
    \node[anchor=north, inner sep=0pt]
      at ([yshift=-160mm]current page.north)
      {\begin{minipage}{120mm}#5\end{minipage}};
    % 진행 도트 (4개)
    \foreach \i in {0, 1, 2, 3} {
      \pgfmathsetmacro{\xpos}{(\i - 1.5) * 6}
      \ifnum\i=#1\relax
        \fill[\taphasecolor{#1}]
          ([xshift=\xpos mm, yshift=-220mm]current page.north) circle (1.5pt);
      \else
        \draw[taSubtext, line width=0.4pt, opacity=0.5]
          ([xshift=\xpos mm, yshift=-220mm]current page.north) circle (1.1pt);
      \fi
    }
    % 푸터 라벨
    \node[anchor=center, text=taSubtext, font=\sffamily\fontsize{7}{9}\selectfont]
      at ([yshift=-228mm]current page.north)
      {PHASE #1\ \ \textbf{·}\ \ #2};
  \end{tikzpicture}
  \cleardoublepage
}

